{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ],
  "installCommand": "cd frontend && npm install && cd .. && pip install -r requirements.txt"
}
