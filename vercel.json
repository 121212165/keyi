{
  "framework": "nextjs",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install && cd .. && pip install -r requirements.txt",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.2.7",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" }
  ]
}
